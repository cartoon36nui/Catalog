const models = RAW.models.map((name,i)=>({
  name, energy: RAW.energy[i],
  spec: Object.fromEntries(Object.keys(RAW.specs).map(k=>[k,RAW.specs[k][i]]))
}));

let curE='all', curQ='', cmpSet=new Set();

function ec(e){ return e==='เบนซิน'?'gas':e==='ดีเซล'?'diesel':'electric'; }
function el(e){ return e==='เบนซิน'?'เบนซิน':e==='ดีเซล'?'ดีเซล':'ไฟฟ้า'; }
function fmt(v){ if(v==null||v==='-')return'—'; return typeof v==='number'?v.toLocaleString():v; }

function setE(val,el_){
  curE=val;
  document.querySelectorAll('.chip').forEach(c=>c.classList.remove('active'));
  el_.classList.add('active');
  render();
}
function doFilter(){ curQ=document.getElementById('search').value.toLowerCase(); render(); }

function getFiltered(){
  return models.filter(m=>(curE==='all'||m.energy===curE)&&(!curQ||m.name.toLowerCase().includes(curQ)));
}

function render(){
  const list=getFiltered();
  document.getElementById('count-lbl').textContent=`${list.length} รุ่น`;
  const g=document.getElementById('grid');
  if(!list.length){ g.innerHTML='<div class="empty"><div style="font-size:48px;margin-bottom:12px">🔍</div><p>ไม่พบรุ่นที่ค้นหา</p></div>'; return; }
  g.innerHTML=list.map(m=>{
    const e=ec(m.energy), sel=cmpSet.has(m.name);
    return `<div class="card${sel?' selected':''}" onclick="openMdl('${m.name}')">
      <div class="card-head">
        <div class="model-nm">${m.name}</div>
        <span class="ebadge ${e}">${el(m.energy)}</span>
      </div>
      <div class="card-specs">
        <div class="srow"><span class="slbl">น้ำหนักยก</span><span class="sval hl">${Number(m.spec['น้ำหนักยกสูงสุด (กก.)']).toLocaleString()} กก.</span></div>
        <div class="srow"><span class="slbl">น้ำหนักรถ</span><span class="sval">${Number(m.spec['น้ำหนักตัวรถ (กก.)']).toLocaleString()} กก.</span></div>
        <div class="srow"><span class="slbl">วงเลี้ยว</span><span class="sval">${m.spec['วงเลี้ยว Wa (มม.)'].toLocaleString()} มม.</span></div>
        <div class="srow"><span class="slbl">ทางลาด</span><span class="sval">${m.spec['ขึ้นทางลาด มีโหลด (%)']}%</span></div>
      </div>
      <div class="card-foot">
        <button class="btn-detail" onclick="event.stopPropagation();openMdl('${m.name}')">ดูสเปคเต็ม</button>
        <button class="btn-cmp${sel?' active':''}" onclick="event.stopPropagation();toggleCmp('${m.name}')">${sel?'✓ เลือกแล้ว':'+ เปรียบเทียบ'}</button>
      </div>
    </div>`;
  }).join('');
}

function openMdl(name){
  const m=models.find(x=>x.name===name); if(!m)return;
  const e=ec(m.energy);
  const secs=[
    {t:'⚖️ น้ำหนัก & ขนาด',k:['น้ำหนักยกสูงสุด (กก.)','โหลดเซ็นเตอร์ (มม.)','น้ำหนักตัวรถ (กก.)','ฐานล้อ (มม.)','ความยาวตัวรถรวมงา (มม.)','ความกว้างตัวรถ (มม.)']},
    {t:'🏗️ เสา & งา',k:['ความสูงเสา ลดระดับ (มม.)','ความสูงการยก (มม.)','ความสูงเสา ยืดออก (มม.)','มุมเอียงเสา หน้า/หลัง (°)','ขนาดงา หนาxกว้างxยาว (มม.)']},
    {t:'🔄 ขับเคลื่อน & เลี้ยว',k:['วงเลี้ยว Wa (มม.)','ทางเดินรถ พาเลท 1000x1200 (มม.)','ความเร็วเดินหน้า มีโหลด','ความเร็วยก มีโหลด (มม./วิ)','ขึ้นทางลาด มีโหลด (%)']},
    {t:'🔧 เครื่องยนต์ / มอเตอร์',k:['เครื่องยนต์','แรงม้า (KW@rpm)','ความจุถังน้ำมัน (ลิตร)','มอเตอร์ขับเคลื่อน (kW)','แรงดันแบตเตอรี่ (V)','แรงดันระบบไฮดรอลิก (บาร์)']},
    {t:'🛞 ล้อ & ยาง',k:['ประเภทยาง','ขนาดยางหน้า']},
  ];
  let html=`<div class="modal-title">${m.name}</div>
    <div class="modal-sub"><span class="ebadge ${e}">${el(m.energy)}</span><span>${m.spec['ประเภทยาง']}</span></div>`;
  secs.forEach(s=>{
    const rows=s.k.map(k=>{
      const v=m.spec[k]; if(v==null||v==='-'||v===null)return'';
      const isN=typeof v==='number';
      return `<div class="si"><span class="si-lbl">${k}</span><span class="si-val${isN?' hl':''}">${isN?Number(v).toLocaleString():v}</span></div>`;
    }).filter(Boolean).join('');
    if(!rows)return;
    html+=`<div class="sec"><div class="sec-title">${s.t}</div><div class="spec-grid">${rows}</div></div>`;
  });
  document.getElementById('mdl-body').innerHTML=html;
  document.getElementById('overlay').classList.add('open');
}
function closeMdl(){ document.getElementById('overlay').classList.remove('open'); }

function toggleCmp(name){
  if(cmpSet.has(name)){ cmpSet.delete(name); }
  else{ if(cmpSet.size>=4){alert('เปรียบเทียบได้สูงสุด 4 รุ่น');return;} cmpSet.add(name); }
  document.getElementById('cmp-cnt').textContent=cmpSet.size;
  document.getElementById('compare-badge').classList.toggle('visible',cmpSet.size>1);
  render();
}

function openCmp(){
  const sel=[...cmpSet].map(n=>models.find(m=>m.name===n)).filter(Boolean);
  if(sel.length<2)return;
  const keys=Object.keys(RAW.specs);
  const hdrs=sel.map(m=>`<th>${m.name}<br><small style="font-weight:400;color:var(--text-dim);font-family:Sarabun">${el(m.energy)}</small></th>`).join('');
  const rows=keys.map(k=>{
    const vals=sel.map(m=>m.spec[k]);
    const nums=vals.map(v=>parseFloat(v)).filter(n=>!isNaN(n));
    const maxN=nums.length===vals.length&&nums.length>1?Math.max(...nums):null;
    const cells=vals.map(v=>{
      const n=parseFloat(v); const best=maxN!==null&&n===maxN;
      return `<td class="${best?'best':''}">${v==null||v===null?'—':fmt(v)}</td>`;
    }).join('');
    return `<tr><td>${k}</td>${cells}</tr>`;
  }).join('');
  document.getElementById('cmp-body').innerHTML=`<table><thead><tr><th>สเปค</th>${hdrs}</tr></thead><tbody>${rows}</tbody></table><p style="margin-top:12px;color:var(--text-faint);font-size:11px"><span style="color:var(--gas)">■</span> ค่าสูงสุดในกลุ่ม</p>`;
  document.getElementById('cmp-panel').classList.add('open');
}
function closeCmp(){ document.getElementById('cmp-panel').classList.remove('open'); }

document.addEventListener('keydown',e=>{ if(e.key==='Escape'){closeMdl();closeCmp();} });
render();
</script>
