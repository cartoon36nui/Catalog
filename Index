<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>รถยก KOMATSU — Spec Catalog</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;500;600;700&family=Bebas+Neue&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0a0c0f;
    --bg2: #111418;
    --bg3: #181c22;
    --border: #252a32;
    --border-bright: #3a424f;
    --accent: #f5a623;
    --text: #e8ecf2;
    --text-dim: #8a95a3;
    --text-faint: #4a5360;
    --gas: #4ade80;
    --diesel: #60a5fa;
    --electric: #a78bfa;
    --red: #f87171;
    --card-h: #1a1f28;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { background: var(--bg); color: var(--text); font-family: 'Sarabun', sans-serif; font-size: 14px; min-height: 100vh; overflow-x: hidden; }

  header {
    position: sticky; top: 0; z-index: 100;
    background: rgba(10,12,15,0.95); backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    padding: 0 20px; display: flex; align-items: center; gap: 16px; height: 56px;
  }
  .logo { font-family: 'Bebas Neue', sans-serif; font-size: 22px; letter-spacing: 3px; color: var(--accent); white-space: nowrap; }
  .logo span { color: var(--text-dim); font-size: 13px; font-family: 'Sarabun', sans-serif; letter-spacing: 1px; }
  .header-right { margin-left: auto; }
  #compare-badge {
    display: none; background: var(--accent); color: #000;
    font-weight: 700; font-size: 12px; padding: 5px 14px; border-radius: 20px;
    cursor: pointer; border: none; font-family: 'Sarabun', sans-serif;
    align-items: center; gap: 6px; white-space: nowrap;
  }
  #compare-badge.visible { display: inline-flex; }

  .filter-bar {
    background: var(--bg2); border-bottom: 1px solid var(--border);
    padding: 12px 20px; display: flex; flex-wrap: wrap; align-items: center; gap: 10px;
  }
  .search-wrap { position: relative; flex: 1; min-width: 200px; max-width: 340px; }
  .search-wrap svg { position: absolute; left: 10px; top: 50%; transform: translateY(-50%); opacity: .4; pointer-events: none; }
  #search {
    width: 100%; background: var(--bg3); border: 1px solid var(--border); border-radius: 8px;
    color: var(--text); font-family: 'Sarabun', sans-serif; font-size: 14px;
    padding: 8px 12px 8px 36px; outline: none; transition: border-color .2s;
  }
  #search:focus { border-color: var(--accent); }
  #search::placeholder { color: var(--text-faint); }
  .chips { display: flex; flex-wrap: wrap; gap: 6px; }
  .chip {
    padding: 5px 14px; border-radius: 20px; border: 1px solid var(--border-bright);
    background: transparent; color: var(--text-dim); font-family: 'Sarabun', sans-serif;
    font-size: 13px; cursor: pointer; transition: all .15s; white-space: nowrap;
  }
  .chip:hover { border-color: var(--accent); color: var(--accent); }
  .chip.active { background: var(--accent); border-color: var(--accent); color: #000; font-weight: 600; }
  .chip.gas.active { background: var(--gas); border-color: var(--gas); color: #000; }
  .chip.diesel.active { background: var(--diesel); border-color: var(--diesel); color: #000; }
  .chip.elec.active { background: var(--electric); border-color: var(--electric); color: #000; }
  .count-lbl { color: var(--text-faint); font-size: 12px; margin-left: auto; white-space: nowrap; }

  .grid-wrap { padding: 20px; }
  #grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(255px, 1fr)); gap: 14px; }

  .card {
    background: var(--card-h); border: 1px solid var(--border); border-radius: 12px;
    padding: 16px; cursor: pointer; transition: border-color .2s, transform .15s, box-shadow .2s;
    position: relative; overflow: hidden;
  }
  .card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; background: linear-gradient(90deg, transparent, var(--accent), transparent); opacity: 0; transition: opacity .2s; }
  .card:hover { border-color: var(--border-bright); transform: translateY(-2px); box-shadow: 0 8px 28px rgba(0,0,0,.4); }
  .card:hover::before, .card.selected::before { opacity: 1; }
  .card.selected { border-color: var(--accent); }

  .card-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 8px; margin-bottom: 10px; }
  .model-nm { font-family: 'JetBrains Mono', monospace; font-size: 15px; font-weight: 500; }
  .ebadge { font-size: 10px; font-weight: 700; padding: 2px 8px; border-radius: 10px; white-space: nowrap; letter-spacing: .5px; flex-shrink: 0; }
  .ebadge.gas      { background: rgba(74,222,128,.15); color: var(--gas); border: 1px solid rgba(74,222,128,.3); }
  .ebadge.diesel   { background: rgba(96,165,250,.15); color: var(--diesel); border: 1px solid rgba(96,165,250,.3); }
  .ebadge.electric { background: rgba(167,139,250,.15); color: var(--electric); border: 1px solid rgba(167,139,250,.3); }

  .card-specs { display: flex; flex-direction: column; gap: 5px; margin-bottom: 12px; }
  .srow { display: flex; justify-content: space-between; align-items: baseline; gap: 8px; }
  .slbl { color: var(--text-faint); font-size: 11px; flex-shrink: 0; }
  .sval { font-family: 'JetBrains Mono', monospace; font-size: 12px; color: var(--text-dim); text-align: right; }
  .sval.hl { color: var(--accent); font-weight: 500; }

  .card-foot { display: flex; align-items: center; justify-content: space-between; }
  .btn-detail { font-family: 'Sarabun', sans-serif; font-size: 12px; color: var(--text-dim); background: transparent; border: 1px solid var(--border-bright); border-radius: 6px; padding: 5px 12px; cursor: pointer; transition: all .15s; }
  .btn-detail:hover { border-color: var(--accent); color: var(--accent); }
  .btn-cmp { font-family: 'Sarabun', sans-serif; font-size: 11px; color: var(--text-faint); background: transparent; border: none; cursor: pointer; padding: 4px 6px; border-radius: 4px; transition: color .15s; }
  .btn-cmp:hover, .btn-cmp.active { color: var(--accent); }

  /* MODAL */
  .overlay { position: fixed; inset: 0; z-index: 200; background: rgba(0,0,0,.75); backdrop-filter: blur(4px); display: flex; align-items: center; justify-content: center; padding: 20px; opacity: 0; pointer-events: none; transition: opacity .2s; }
  .overlay.open { opacity: 1; pointer-events: all; }
  .modal { background: var(--bg2); border: 1px solid var(--border-bright); border-radius: 16px; width: 100%; max-width: 720px; max-height: 90vh; overflow-y: auto; padding: 28px; position: relative; transform: translateY(20px); transition: transform .2s; }
  .overlay.open .modal { transform: translateY(0); }
  .modal-title { font-family: 'JetBrains Mono', monospace; font-size: 24px; font-weight: 500; color: var(--accent); margin-bottom: 4px; }
  .modal-sub { color: var(--text-faint); font-size: 13px; margin-bottom: 20px; display: flex; gap: 12px; align-items: center; }
  .modal-close { position: absolute; top: 18px; right: 18px; background: var(--bg3); border: 1px solid var(--border); border-radius: 8px; color: var(--text-dim); cursor: pointer; padding: 5px 10px; font-size: 18px; line-height: 1; transition: all .15s; }
  .modal-close:hover { border-color: var(--red); color: var(--red); }
  .sec { margin-bottom: 20px; }
  .sec-title { font-size: 10px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--text-faint); border-bottom: 1px solid var(--border); padding-bottom: 6px; margin-bottom: 10px; }
  .spec-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0 20px; }
  .si { display: flex; justify-content: space-between; align-items: baseline; gap: 8px; padding: 5px 0; border-bottom: 1px solid rgba(255,255,255,.03); }
  .si-lbl { color: var(--text-dim); font-size: 12px; flex: 1; }
  .si-val { font-family: 'JetBrains Mono', monospace; font-size: 12px; color: var(--text); text-align: right; flex-shrink: 0; }
  .si-val.hl { color: var(--accent); }

  /* COMPARE PANEL */
  #cmp-panel { position: fixed; inset: 0; z-index: 300; background: var(--bg); overflow-y: auto; transform: translateX(100%); transition: transform .3s cubic-bezier(.4,0,.2,1); }
  #cmp-panel.open { transform: none; }
  .cp-head { position: sticky; top: 0; z-index: 10; background: rgba(10,12,15,.95); backdrop-filter: blur(12px); border-bottom: 1px solid var(--border); padding: 14px 24px; display: flex; align-items: center; gap: 16px; }
  .cp-title { font-family: 'Bebas Neue', sans-serif; font-size: 20px; letter-spacing: 2px; color: var(--accent); }
  .cp-close { margin-left: auto; background: var(--bg3); border: 1px solid var(--border); border-radius: 8px; color: var(--text-dim); cursor: pointer; padding: 6px 14px; font-family: 'Sarabun', sans-serif; font-size: 13px; transition: all .15s; }
  .cp-close:hover { border-color: var(--red); color: var(--red); }
  .cp-body { padding: 24px; overflow-x: auto; }
  table { border-collapse: collapse; width: 100%; min-width: 500px; }
  th { background: var(--bg3); padding: 10px 14px; text-align: left; font-family: 'JetBrains Mono', monospace; font-size: 13px; color: var(--accent); border: 1px solid var(--border); white-space: nowrap; }
  th:first-child { color: var(--text-faint); font-size: 11px; font-family: 'Sarabun', sans-serif; min-width: 200px; }
  td { padding: 8px 14px; border: 1px solid var(--border); font-family: 'JetBrains Mono', monospace; font-size: 12px; color: var(--text-dim); }
  tr:hover td { background: rgba(255,255,255,.02); }
  td:first-child { font-family: 'Sarabun', sans-serif; color: var(--text-dim); }
  td.best { color: var(--gas); font-weight: 600; }

  .empty { text-align: center; padding: 80px 20px; color: var(--text-faint); grid-column: 1/-1; }
  ::-webkit-scrollbar { width: 6px; height: 6px; }
  ::-webkit-scrollbar-track { background: var(--bg); }
  ::-webkit-scrollbar-thumb { background: var(--border-bright); border-radius: 3px; }
</style>
</head>
